# Monetura Platform — app.monetura.com
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secure-random-secret-here
NEXTAUTH_URL=http://localhost:3001

# Database (same connection as Vercel — use existing DigitalOcean MySQL URL locally)
DATABASE_URL=mysql://user:password@host:port/database?ssl={"rejectUnauthorized":true}
