# Monetura Platform — app.monetura.com
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secure-random-secret-here
NEXTAUTH_URL=http://localhost:3001

# Database (same connection as Vercel — use existing DigitalOcean MySQL URL locally)
DATABASE_URL=mysql://user:password@host:port/database?ssl={"rejectUnauthorized":true}

# AWS S3 — photo uploads
# Bucket must have CORS enabled for PUT from browser (run scripts/set-s3-cors.mjs once)
AWS_S3_BUCKET=monetura-platform-media
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# Public base URL — no trailing slash
# Format: https://{bucket}.s3.{region}.amazonaws.com  OR a CloudFront URL
NEXT_PUBLIC_S3_BASE_URL=https://monetura-platform-media.s3.us-east-1.amazonaws.com
